# presentation/.env.local — server-side secrets for the AgentForce API
#
# Required by /api/agents, /api/agents/session, /api/agents/message
# (see presentation/lib/agentforceAuth.ts).
#
# The connected app lives in the same org you're publishing the demo agent to.
# Create one with OAuth Settings → Enable Client Credentials Flow, scopes
# `chatbot_api` and `sfap_api` (and `api` for the SOQL list call).

NEXT_PUBLIC_SALESFORCE_INSTANCE_URL=https://orgfarm-22ccc7c65d.my.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
